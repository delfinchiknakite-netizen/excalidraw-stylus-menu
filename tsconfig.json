{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2018",
    "moduleResolution": "node",
    "allowJs": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strict": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ES2018", "ES2019", "ES2020"]
  },
  "include": ["src/**/*.ts"]
}
